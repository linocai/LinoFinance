LINOFINANCE_ENVIRONMENT=local
LINOFINANCE_DATABASE_URL=postgresql+psycopg://linofinance:linofinance@localhost:5432/linofinance
LINOFINANCE_API_HOST=127.0.0.1
LINOFINANCE_API_PORT=8000
LINOFINANCE_API_AUTH_TOKEN=
LINOFINANCE_API_RATE_LIMIT_ENABLED=false
LINOFINANCE_API_RATE_LIMIT_PER_MINUTE=120
LINOFINANCE_TRUSTED_PROXY_HEADERS=false
LINOFINANCE_CORS_ALLOWED_ORIGINS=[]
LINOFINANCE_PUBLIC_DOCS_ENABLED=true
LINOFINANCE_LOG_LEVEL=INFO
LINOFINANCE_BACKUP_DIR=.backups
LINOFINANCE_AI_PROVIDER=openai_compatible
LINOFINANCE_AI_API_BASE_URL=
LINOFINANCE_AI_API_KEY=
LINOFINANCE_AI_MODEL=
LINOFINANCE_AI_REQUEST_TIMEOUT_SECONDS=30
LINOFINANCE_AI_AUTO_CONFIRM_LIMIT_CNY=1000
